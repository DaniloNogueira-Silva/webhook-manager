generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

enum WebhookEventStatus {
  RECEIVED
  QUEUED
  PROCESSING
  PROCESSED
  FAILED
  DEAD_LETTERED
}

enum PartnerAuthType {
  HMAC
  NONE
  BEARER_TOKEN
  BASIC
  API_KEY
}

enum PartnerSignatureAlgorithm {
  HMAC_SHA1
  HMAC_SHA256
  HMAC_SHA384
  HMAC_SHA512
}

model WebhookRawEvent {
  id                        String                     @id @default(uuid())
  source                    String
  eventType                 String
  externalEventId           String?
  signature                 String?
  headersJson               Json
  payloadJson               Json
  status                    WebhookEventStatus         @default(RECEIVED)
  lastError                 String?
  receivedAt                DateTime                   @default(now())
  processedAt               DateTime?
  webhookProcessingAttempts WebhookProcessingAttempt[]

  @@unique([source, externalEventId])
  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
  @@map("webhook_raw_events")
}

model PartnerIntegration {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  authType                  PartnerAuthType            @default(HMAC)
  signatureAlgorithm        PartnerSignatureAlgorithm?
  secret                    String?
  signatureHeaderName       String?
  signaturePrefix           String?
  timestampHeaderName       String?
  timestampToleranceSeconds Int?
  signedPayloadTemplate     String?
  authHeaderName            String?
  bearerToken               String?
  apiKeyHeaderName          String?
  apiKeyValue               String?
  basicUsername             String?
  basicPassword             String?

  eventTypePath        String?
  externalEventIdPath  String?
  deliveryIdHeaderName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("partner_integrations")
}

enum WebhookProcessingAttemptStatus {
  STARTED
  SUCCEEDED
  FAILED
}

model WebhookProcessingAttempt {
  id             String                         @id @default(uuid())
  webhookEventId String
  attemptNumber  Int
  status         WebhookProcessingAttemptStatus @default(STARTED)
  errorMessage   String?
  startedAt      DateTime                       @default(now())
  finishedAt     DateTime?
  latencyMs      Int?

  webhookEvent WebhookRawEvent @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  @@unique([webhookEventId, attemptNumber])
  @@index([webhookEventId])
  @@index([status])
  @@index([startedAt])
  @@map("webhook_processing_attempts")
}
